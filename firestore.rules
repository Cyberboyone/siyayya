rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 🔴 Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isBannedOrSuspended() {
      // Look up user status in firestore to prevent banned users from writing
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'banned' || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'suspended' ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned == true);
    }

    function canWrite() {
      return isAuthenticated() && !isBannedOrSuspended();
    }
    
    function isAdmin() {
      // Secure Role-Based Access Control using Custom Claims
      // Fallback to email for initial setup if needed, but prefer custom claims
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        ('email' in request.auth.token && request.auth.token.email.lower() == 'muhammadmusab372@gmail.com')
      );
    }

    // 👑 Only this single account may grant/revoke admin access. Kept
    // separate from isAdmin() so that even an admin promoted through the
    // dashboard can never escalate anyone's privileges (including their
    // own) via a direct Firestore write, only the account owner can.
    function isSuperAdminToken() {
      return isAuthenticated() &&
        'email' in request.auth.token &&
        request.auth.token.email.lower() == 'muhammadmusab372@gmail.com';
    }

    // True if this write is attempting to change admin-escalation fields.
    // request.resource is null on delete, so that's never treated as an
    // escalation attempt here (deletion is governed separately below).
    function touchesAdminFields() {
      return request.resource != null && (
        ('account_type' in request.resource.data &&
           (resource == null || request.resource.data.account_type != resource.data.account_type)) ||
        ('isAdmin' in request.resource.data &&
           (resource == null || request.resource.data.isAdmin != resource.data.isAdmin))
      );
    }

    // 🟢 GLOBAL ADMIN ACCESS
    match /{document=**} {
      allow read: if isAdmin();
      // Regular admins retain full write access for moderation, EXCEPT they
      // can never change account_type/isAdmin on any document — only the
      // super admin account can grant or revoke admin privileges.
      allow write: if isAdmin() && (!touchesAdminFields() || isSuperAdminToken());
    }

    // 🔴 User Profiles
    match /users/{userId} {
      // Anyone authenticated can read user profiles (needed for marketplace display)
      allow read: if isAuthenticated();
      
      // Users can only create their own profile, and cannot give themselves admin privileges or spoof verification/ban status
      allow create: if isOwner(userId) && 
                    (!('account_type' in request.resource.data) || request.resource.data.account_type != 'admin') &&
                    (!('isBanned' in request.resource.data) || request.resource.data.isBanned != true) &&
                    (!('isVerified' in request.resource.data) || request.resource.data.isVerified != true) &&
                    (!('referralCount' in request.resource.data)) &&
                    (!('referralRewardCredits' in request.resource.data)) &&
                    (!('referredBy' in request.resource.data));
                    
      // Users can only update their own profile, and cannot escalate privileges
      allow update: if isOwner(userId) && 
                    (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['account_type', 'isBanned', 'status', 'isVerified', 'referralCount', 'referralRewardCredits', 'referredBy', 'referredByCode', 'referredAt', 'badges']));
                    
      allow delete: if isOwner(userId);
    }

    // 🔴 Marketplace Collections
    match /products/{productId} {
      // Anyone can view products
      allow read: if true;
      
      // Authenticated users who are not banned can create products, maximum 5 images
      allow create: if canWrite() && request.resource.data.ownerId == request.auth.uid &&
                    (!('images' in request.resource.data) || request.resource.data.images.size() <= 5);
                    
      // Owners can update their own products, but cannot change the ownerId or status to approved if it was removed
      allow update: if isOwner(resource.data.ownerId) && canWrite() && 
                    request.resource.data.ownerId == resource.data.ownerId &&
                    (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'isFeatured', 'ownerId'])) &&
                    (!('images' in request.resource.data) || request.resource.data.images.size() <= 5);
                    
      allow delete: if isOwner(resource.data.ownerId);
    }
    
    match /services/{serviceId} {
      allow read: if true;
      allow create: if canWrite() && request.resource.data.ownerId == request.auth.uid &&
                    (!('images' in request.resource.data) || request.resource.data.images.size() <= 5);
      allow update: if isOwner(resource.data.ownerId) && canWrite() && 
                    request.resource.data.ownerId == resource.data.ownerId &&
                    (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'isFeatured', 'ownerId'])) &&
                    (!('images' in request.resource.data) || request.resource.data.images.size() <= 5);
      allow delete: if isOwner(resource.data.ownerId);
    }
    
    match /requests/{requestId} {
      allow read: if true;
      allow create: if canWrite() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner(resource.data.ownerId) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isOwner(resource.data.ownerId);
    }

    // 🔴 Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }
    
    // 🔴 Reports (Abuse/Flagging)
    match /reports/{reportId} {
      // Only admins can read, update, or delete reports
      allow read, update, delete: if isAdmin();
      // Any authenticated user can file a report
      allow create: if isAuthenticated();
    }

    // 🔴 Contact Us Messages
    // The /contact page is public (no sign-in required), so anyone — including
    // guests — must be able to submit. Only admins can read/manage submissions
    // to prevent messages (which may include personal contact info) from being
    // publicly readable.
    match /contact_messages/{messageId} {
      allow read, update, delete: if isAdmin();
      allow create: if request.resource.data.name is string && request.resource.data.name.size() > 0 &&
                    request.resource.data.email is string && request.resource.data.email.size() > 0 &&
                    request.resource.data.message is string && request.resource.data.message.size() > 0;
    }
    
    // 🔴 Referrals
    match /referrals/{referralId} {
      allow read: if isAuthenticated() && (
        resource.data.referrerId == request.auth.uid ||
        resource.data.referredUserId == request.auth.uid
      );
      allow create, update, delete: if isAdmin();
    }

    // 🔴 Forum System Rules
    match /campuses/{campusId} {
      // Campuses are readable by all
      allow read: if true;
      // Only admins can modify campuses
      allow write: if isAdmin();
    }

    // 🔴 User Follows
    match /user_follows/{followId} {
      allow read: if true;
      // Follow ID must start with the user's UID to prevent spoofing
      allow create, delete: if isAuthenticated() && followId.startsWith(request.auth.uid);
    }

    // 🔴 In-App Notifications
    // Actual per-user subcollection used by the app: users/{userId}/notifications/{notificationId}
    // (navbar account-menu notification badge/list, NotificationsPage, notificationService.ts).
    // This was previously missing its own rule entirely — Firestore subcollections do NOT
    // inherit the parent /users/{userId} rules, so every read/write here silently fell through
    // to "denied" for normal users (only the global admin wildcard matched), meaning
    // notifications never worked for any non-admin user.
    match /users/{userId}/notifications/{notificationId} {
      // Only the notification's owner can read their own notifications
      allow read: if isOwner(userId);
      // Any authenticated, non-banned user can create a notification in someone else's
      // inbox (e.g. a buyer's order notifies an admin, a review notifies a seller), as long
      // as the notification's userId field matches the subcollection owner.
      allow create: if canWrite() && request.resource.data.userId == userId;
      // The owner can only toggle the read flag, not rewrite notification content
      allow update: if isOwner(userId) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(userId);
    }

    // 🔴 Notifications (legacy/unused top-level collection kept for backward compatibility)
    match /user_notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      // Services or authenticated users can create notifications
      allow create: if isAuthenticated();
      // Users can only mark their own notifications as read
      allow update: if isAuthenticated() && resource.data.recipientId == request.auth.uid && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
    }

    // 🔴 Messaging System
    match /conversations/{conversationId} {
      // Allow read if user is a participant
      allow read: if isAuthenticated() && 
                  (request.auth.uid in resource.data.participantIds);
      
      // Allow create if user is a participant in the new conversation
      allow create: if isAuthenticated() && 
                    (request.auth.uid in request.resource.data.participantIds);
      
      // Allow update for lastMessage, unreadCounts, updatedAt, and typing
      allow update: if isAuthenticated() && 
                    (request.auth.uid in resource.data.participantIds);

      // Messages sub-collection
      match /messages/{messageId} {
        // Participants can read messages
        allow read: if isAuthenticated() && 
                    (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds);
        // Only the actual sender can create a message
        allow create: if canWrite() && request.auth.uid == request.resource.data.senderId;
      }
    }
    
    // 🔴 Orders & Payments — REMOVED (cart/checkout/Paystack payment flow was
    // fully removed from the app; the marketplace is a browse-and-contact-
    // seller-directly model until a future subscription feature ships). No
    // match block here means all reads/writes to /orders/{orderId} now fall
    // through to the default-deny rule at the bottom of this file.
  }
}
