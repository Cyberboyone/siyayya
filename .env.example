# Siyayya Environment Template
# Copy this file to .env and fill in your actual credentials

# SMTP Configuration for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Application URL (used for frontend redirects)
# For local development: http://localhost:5173
# For production: https://your-app.vercel.app
VITE_APP_URL=http://localhost:5173

# Google OAuth 2.0 Credentials
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# IMPORTANT: Must exactly match one of the authorized redirect URIs in Google Console
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/callback/google

# Firebase Admin SDK (Server-side)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Cloud Configuration (Vite/Client-side)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Admin Configuration (comma-separated list of admin emails)
# These emails get automatic admin role on login
VITE_ADMIN_EMAILS=your-admin@gmail.com
ADMIN_EMAILS=your-admin@gmail.com
